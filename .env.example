# K-Palantir ACW 자동화 환경변수

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Databricks
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi-your-token-here
DATABRICKS_SQL_WAREHOUSE_ID=your-warehouse-id

# Firebase (Auth)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# KT STT (에이센)
KT_ACEN_STT_ENDPOINT=https://stt.aicc.kt.com/v1
KT_ACEN_STT_API_KEY=your-kt-stt-key

# CRM API (Write-back 대상)
CRM_API_ENDPOINT=https://crm.internal.bank.com/api/v2
CRM_API_KEY=your-crm-key

# ACD (상담원 큐 관리)
ACD_API_ENDPOINT=https://acd.internal.bank.com/api/v1
ACD_API_KEY=your-acd-key
